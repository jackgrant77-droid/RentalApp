<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StarterApp.Views.MainPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StarterApp.ViewModels"
             Title="{Binding Title}">

    <RefreshView IsRefreshing="{Binding IsBusy}" 
                 Command="{Binding RefreshDataCommand}">
        <ScrollView>
            <Grid Padding="20" RowSpacing="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Welcome Section -->
                <Border Grid.Row="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        Padding="20"
                        HeightRequest="120">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>

                    <StackLayout VerticalOptions="Center">
                        <Label Text="{Binding WelcomeMessage}"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center" />
                        <Label Text="{Binding CurrentUser.Email}"
                               FontSize="14"
                               TextColor="White"
                               Opacity="0.8"
                               HorizontalOptions="Center" />
                    </StackLayout>
                </Border>

                <!-- Error Display -->
                <Border Grid.Row="1"
                        BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#1B0000}"
                        Stroke="{AppThemeBinding Light=#F44336, Dark=#EF5350}"
                        StrokeThickness="1"
                        Padding="15"
                        IsVisible="{Binding HasError}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>

                    <Label Text="{Binding ErrorMessage}"
                           TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}"
                           FontSize="14" />
                </Border>

                <!-- Quick Actions -->
                <Label Grid.Row="2"
                       Text="Quick Actions"
                       FontSize="20"
                       FontAttributes="Bold"
                       Margin="0,10,0,10" />

                <!-- Action Cards -->
                <StackLayout Grid.Row="3" Spacing="15">

                    <Button
                        Text="View Rentals"
                        Clicked="OnViewRentalsClicked" />

                    <Button
                        Text="View Items"
                        Clicked="OnViewItemsClicked" />

                    <Button
                        Text="Profile Settings"
                        Command="{Binding NavigateToProfileCommand}" />

                    <Button
                        Text="App Settings"
                        Command="{Binding NavigateToSettingsCommand}" />

                    <Button
                        Text="User Management"
                        Command="{Binding NavigateToUserListCommand}"
                        IsVisible="{Binding IsAdmin}" />

                </StackLayout>
            </Grid>
        </ScrollView>
    </RefreshView>
</ContentPage>