<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="StarterApp.Views.RentalsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Rentals">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Label
            Text="Rental Requests"
            FontSize="24"
            FontAttributes="Bold" />

        <Button
            Text="Load Rentals"
            Command="{Binding LoadRentalsCommand}" />

        <CollectionView ItemsSource="{Binding Rentals}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="12" Margin="0,5">
                        <VerticalStackLayout Spacing="6">

                            <Label Text="{Binding Item.Title}" FontAttributes="Bold" />
                            <Label Text="{Binding Status}" />
                            <Label Text="{Binding StartDate, StringFormat='Start: {0:dd/MM/yyyy}'}" />
                            <Label Text="{Binding EndDate, StringFormat='End: {0:dd/MM/yyyy}'}" />
                            <Label Text="{Binding TotalPrice, StringFormat='Total: £{0:F2}'}" />

                            <HorizontalStackLayout Spacing="10">
                                <Button
                                    Text="Approve"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ApproveRentalCommand}"
                                    CommandParameter="{Binding .}" />

                                <Button
                                    Text="Reject"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RejectRentalCommand}"
                                    CommandParameter="{Binding .}" />

                                <Button
                                    Text="Leave Review"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ReviewRentalCommand}"
                                    CommandParameter="{Binding .}" />


                            </HorizontalStackLayout>

                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>